{
    "name": "second-brain",
    "version": "0.4.0",
    "description": "Git sync + Claude integration plugin for Obsidian",
    "main": "main.js",
    "scripts": {
        "dev": "mkdir -p dist && cp manifest.json styles.css dist/ && node esbuild.config.mjs dev",
        "build": "node esbuild.config.mjs production && cp manifest.json styles.css dist/",
        "release": "node scripts/release.mjs"
    },
    "keywords": [
        "obsidian",
        "git",
        "sync",
        "claude"
    ],
    "author": "subicura",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/subicura/second-brain-plugin.git"
    },
    "bugs": {
        "url": "https://github.com/subicura/second-brain-plugin/issues"
    },
    "homepage": "https://github.com/subicura/second-brain-plugin#readme",
    "private": true,
    "devDependencies": {
        "@types/node": "^22.19.10",
        "builtin-modules": "^3.3.0",
        "esbuild": "^0.24.2",
        "obsidian": "^1.11.4",
        "tslib": "^2.8.1",
        "typescript": "5.8.3"
    },
    "dependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.2.71",
        "buffer": "^6.0.3",
        "isomorphic-git": "^1.36.3",
        "simple-git": "^3.27.0"
    }
}
